<?php
defined('BASEPATH') OR exit('No direct script access allowed');

class Whatsapp_model extends CI_Model
{

    public function auco($data) {
        $query = $this->db->query("SELECT id, concat(name,' (',account,')') AS 'label', name AS 'value'
            from whatsapp_contact where id_wacta = ?
            and (name like '%".$data['bus']."%' or account like '%".$data['bus']."%')",
            [$data['dep']]);
        return $query->result();
    }

    public function mis_wactas($wid = false, $act = '') {
        if ($this->udata['perfil']=='admin') {
            $where_act = ($act === '') ? '' : "AND active = $act";
            $where_in = '';
        } else {
            $where_act = ($act === '') ? "AND active = 1" : "AND active = $act";
            $ids = ($wid) ? $wid : $this->udata['whatsapp'];
            $where_in = "AND id in ($ids)";

            if (empty($ids)) return false;
        }
        $query = $this->db->query("SELECT id, nombre AS 'name' FROM `whatsapp_cuentas` WHERE 1 = 1 $where_in $where_act");

        return $query->result();
    }

    public function get_cuenta($idcaotoken) {
        // ID chat api o Wabox token
        $query = $this->db->query('SELECT * from `whatsapp_cuentas`
            where (`cuenta` = ? or `idchatapi` = ? ) and `active` = 1', [$idcaotoken, $idcaotoken]);

        return $query->row();
    }

    public function sale_texto($data) {
	/*  watext texto, obligatorio
            ses    objecto, opcional, descarta cid, cto, sid y wacta
            sid    entero, opcional, session id, se crea una nueva si no viene
            cid    entero, obligatorio, contact id
            cto    objeto, opcional, contacto descarta obligatorio cid, ya viene
            uid    entero, opcional, user id, usuario activo en caso de vacío,
                   si no hay session es obligatorio, ejemplo: cron.
        */
        if (empty($data['watext'])) return array('error' => 'No puedes enviar un mensaje vacío');
        if (!empty($data['cto'])) {
            $cto = $data['cto'];
        } elseif (!empty($data['cid'])) {
            $cto = $this->db->query("SELECT * FROM whatsapp_contact WHERE id = ?", [$data['cid']])->row();
        } else {
            $cto = null;
        }
        if ($cto) {
            $cid = $cto->id;
            $wid = $cto->id_wacta;
        }

        // Traigo todos los datos de la sesión en caso de venir un objeto sesión $ses o un id de sesión $sid
        if (!empty($data['ses'])) {
            $ses = $data['ses'];
        } elseif (!empty($data['sid'])) {
            $ses = $this->db->query("SELECT * FROM whatsapp_session WHERE id = ?", [$data['sid']])->row();
        } elseif ($cid && $wid) {
            // Si no hay datos de sesión será una nueva saliente, debe haber un contacto destino
            $ses = $this->creases(["cid"=>$cid,"wid"=>$wid]);
        } else {
            return array('error' => 'Datos de sesión o contácto no válidos');
        }
        $sid = $ses->id;
        $uid = $ses->id_user;
        $msv = $ses->type == 'Masivo' ? true : false;
        if (!$cto && $msv) {
            return array('error' => 'Contacto no válido para envío masivo.');
        } else if (!$cto) {
            $cto = $this->db->query("SELECT * FROM whatsapp_contact WHERE id = ?", [$ses->id_contact])->row();
            $cid = $cto->id;
            $wid = $cto->id_wacta;
        }
        if ($wid != $ses->id_wacta) {
            return array('error' => "La cuenta de WhatsApp $wid no coincide con la sesión {$ses->id_wacta}.");
        }

        // Valída wacta existente y activa
        $wacta = $this->db->query("SELECT * from `whatsapp_cuentas`
            where `id` = ? and `active` = 1", [$wid])->row();
        if (!$wacta) return array('error' => 'Cuenta inactiva, consulta con tu supervisor.');

        $this->db->query("INSERT into `whatsapp_entry`
            (id_contact, id_user, id_session, id_wacta, message, datetime_received, type, status, watype)
            values (?, ?, ?, ?, ?, now(), 'Saliente', 'Por enviar', 'chat')",
            array($cid, $uid, $sid, $wid, $data['watext'])
        );
        $mid = $this->db->insert_id();
        if (empty($wacta->idchatapi)) {
            // proceso para Wabox
            $query = $this->db->query("SELECT * FROM extapi WHERE `name` = 'Wabox App'"); // ToDo relacionar en tabla cuentas Whatsapp
            $wabox = $query->row();
            if (!empty($this->udata) && filter_var($this->udata['servask'], FILTER_VALIDATE_IP)) {
                $cmid = explode(".", $this->udata['servask'])[3]."-".$mid;
            } else {
                $cmid = substr(explode(".", getenv('SRVR_IP'))[3], 0, 3)."-".$mid;
            }
            if ($msv) {
                $data = [
                    "token"       => $wacta->token,
                    "uid"         => $wacta->cuenta,
                    "to"          => $cnum,
                    "custom_uid"  => $cmid,
                    "url"         => "https://ccphonex.assertivebusiness.com.mx/wafiles/1762996018203.png",
                    "description" => $data['watext'],
                ];
                $url = $wabox->url . "send/image";
            } else {
                $data = [
                    "token"      => $wacta->token,
                    "uid"        => $wacta->cuenta,
                    "to"         => $cto->account,
                    "custom_uid" => $cmid,
                    "text"       => $data['watext'],
                ];                $url = $wabox->url . "send/chat";

            }
        } else {
            // proceso para One message 1msg, antes Chat-api
            $query = $this->db->query("SELECT * FROM extapi WHERE `name` = 'One Message'"); // ToDo relacionar en tabla cuentas Whatsapp
            $onemsg = $query->row();
            $data = [
                "token" => $wacta->token,
                "phone" => $cto->account,
                "body"  => $data['watext'],
            ];
            $url = $onemsg->url . $wacta->idchatapi . "/sendMessage";
        }
        $respu = doReq(["url"=>$url, "method"=>"POST", "body"=>$data, 'proto'=>'x-www-form-urlencoded']);
        $respu = json_decode($respu["data"], true);
        if (is_array($respu)) {
            $respu['url_local'] = $url;
        } else {
            $respu." url: ".$url;
        }
        $this->actualizar($mid, $respu);
        if (!$msv) {
            $this->db->query("UPDATE `whatsapp_entry` set `id_user` = ?, `status` = 'Respondido'
                where `id_contact` = ? and `type` = 'Entrante' AND `status` = 'Recibido'", array($uid, $cid)
            );
            $this->db->query("UPDATE `whatsapp_entry` SET `id_user` = ?, `id_session` = ?
                WHERE (`id_user` is null or `id_session` is null) and `id_contact` = ?", [$uid, $sid, $cid]);
            $this->db->query("UPDATE `whatsapp_session` set `datetime_start` = now()
                where `id` = ? and `datetime_start` is null", [$sid]
            );
        }

        if (empty($respu["error"])) {
            $respu["sid"] = $sid;
            $respu["lastid"] = $mid;
        }

        return $respu;
    }

    public function sale_media($data) {
        if (empty($data['wid']) || empty($data['cid']) || empty($data['wac'])) {
            return array('error' => 'Información incorrecta.');
        }
        $cid     = $data['cid']; // ID del contacto a quien se envía
        $cnum    = $data['wac']; // Número del contacto a quien se envía
        $wid     = $data['wid']; // ID de la cuenta de Whatssapp desde la que se envía
        $wacta   = $this->db->query("SELECT * from `whatsapp_cuentas`
            where `id` = ? and `active` = 1", [$wid])->row();
        if (!$wacta) return array('error' => 'Cuenta inactiva, consulta con tu supervisor.');

        $lurl = 'https://'.$_SERVER['HTTP_HOST'].site_url('wafiles').'/'.$data['archivo'];
        if ($wacta->almacen != "localhost") {
            try {
                $connection = ssh2_connect($wacta->almacen, 10100);
                ssh2_auth_password($connection, 'root', 'Ohpoojie0lahjail');
                ssh2_scp_send($connection, FCPATH . 'wafiles/' . $data['archivo'], '/var/www/html/wafiles/ext/'.$data['archivo'], 0775);
                $url = 'https://gw.assertivebusiness.com/wafiles/ext/'.$data['archivo'];
            } catch (Exeption $e) {
                return ['error' => 'No se envió el archivo al almacen seleccionado '.$e->getMessage()];
            }
        } else {
            $url = $lurl;
        }
        $uid     = $this->session->userdata('uid');
        $sid     = (empty($data['sid'])) ? $this->creases(["cid"=>$cid,"wid"=>$wid])->id : $data['sid'];
        $images  = array('.jpg','.jpeg','.gif','.png');
        $videos  = array('.mpg','.mp4','.ogg','.ogv');
        $documt  = array('.pdf','.xls','.xlsx','.doc','.docx','.zip');
        $waboxtipo = 'media';
        if (in_array($data['ext'], $images)) {
            $wt = $waboxtipo = 'image';
        } else if (in_array($data['ext'], $videos)) {
            $wt = 'video';
        } else if (in_array($data['ext'], $documt)) {
            $wt = 'document';
        } else {
            $wt = 'media';
        }
        $dura = ($wt == 'video') ? $this->get_video_attributes($data['url'])['duration'] : 0;
        $thumb = ($wt == 'image') ? make_thumb(FCPATH . 'wafiles/' . $data['archivo']) : "";
        $query = $this->db->query("INSERT into `whatsapp_entry`
            (`id_contact`, `id_user`, `id_session`, `id_wacta`, `datetime_received`,
                `type`, `status`, `watype`, `size`, `mimetype`, `thumb`, `url`, `duration`)
            values (?, ?, ?, ?, now(), 'Saliente', 'Por enviar', ?, ?, ?, ?, ?, ?)",
            array($cid, $uid, $sid, $wid, $wt, $data["size"], $data["mtype"], $thumb, $data['archivo'], $dura));
        $mid = $this->db->insert_id();
        if ($query) {
            if (empty($wacta->idchatapi)) { // Proceso para Wabox
                $query = $this->db->query("SELECT * FROM extapi WHERE id = 2"); // ToDo relacionar en tabla cuentas Whatsapp
                $wabox = $query->row();
                if (filter_var($this->udata['servask'], FILTER_VALIDATE_IP)) {
                    $cmid = explode(".", $this->udata['servask'])[3]."-".$mid;
                } else {
                    $cmid = substr(explode(".", $_SERVER['HTTP_HOST'])[0], 0, 3)."-".$mid;
                }
                $data = [
                    "token"      => $wacta->token,
                    "uid"        => $wacta->cuenta,
                    "to"         => $cnum,
                    "custom_uid" => $cmid,
                    "url"        => $url,
                ];
                $url = $wabox->url . "send/" . $waboxtipo;
            } else { // Proceso para One Message 1msg, antes Chat-api
                $query = $this->db->query("SELECT * FROM extapi WHERE id = 1"); // ToDo relacionar en tabla cuentas Whatsapp
                $onemsg = $query->row();
                $data = [
                    "token"    => $wacta->token,
                    "phone"    => $cnum,
                    "body"     => $url,
                    "filename" => $data['archivo'],
                ];
                $url = $onemsg->url . $wacta->idchatapi . "/sendFile";
            }
            $respu = doReq(["url"=>$url, "method"=>"POST", "body"=>$data]);
            $respu = json_decode($respu["data"], true);
            $this->actualizar($mid, json_encode($respu));
            $this->db->query("UPDATE `whatsapp_entry` set `id_user` = ?, `status` = 'Respondido'
                where `id_contact` = ? and `type` = 'Entrante' AND `status` = 'Recibido'", array($uid, $cid)
            );
            $this->db->query("UPDATE `whatsapp_session` set `datetime_start` = now()
                where `id` = ? and `datetime_start` is null", [$sid]
            );

            $respu["sid"] = $sid;
        } else {
            $respu['error'] = $this->db->_error_message();
        }

        return $respu;
    }

    public function entrante_wabox($data, $wac) {
        $resp = ["error"=>"Data incorrecta"];
        $cid = $this->valida_contacto($data->contact, $wac->id);
        if ($cid) {
            if ($data->event == "ack") return true; // Trabajo pendiente
            $body     = $data->message->body;
            $textRec  = $text = (!empty($body->text)) ? $body->text : "";
            $caption  = (!empty($body->caption)) ? $body->caption : "";
            $mimetype = (!empty($body->mimetype)) ? $body->mimetype : "";
            $size     = (!empty($body->size)) ? $body->size : "";
            $duration = (!empty($body->duration)) ? $body->duration : "0";
            $thumb    = (!empty($body->thumb)) ? $body->thumb : "";
            $url      = (!empty($body->url)) ? $body->url : "";
            $lat      = (!empty($body->lat)) ? $body->lat : "";
            $lng      = (!empty($body->lng)) ? $body->lng : "";
            if ($data->message->dir == 'o') {
                $query = $this->db->query("SELECT id_user, id_session FROM whatsapp_entry
                    WHERE id_contact = ? AND id_user IS NOT NULL ORDER BY id DESC LIMIT 1", [$cid]);
                $reto = $query->row();
                $resp  = $this->db->query("INSERT INTO `whatsapp_entry` (`id_contact`,
                    `id_user`, `id_session`, `json`, `datetime_received`, `type`,
                    `status`, `watype`, `id_wacta`)
                    values (?, ?, ?, ?, now(), 'Saliente', 'Confirma', ?, ?)",
                    array($cid, $reto->id_user, $reto->id_session, json_encode($data->message),
                        $data->message->type, $wac->id
                    )
                );
            } else {
                $ses = $this->creases(["cid"=>$cid,"wid"=>$wac->id,"tipo"=>'Entrante']); // Crea sesión o trae la sesión activa
                if(in_array($data->message->type, ["media", "image", "video", "document"])){
                    $url = $this->getFile($url, 'w');
                }
                if ($ses->subtipo == 'Bot' && !empty($wac->nobotlog)) {
                    $data->message->body = $text = "🙂"; // Quitar textos de registros de entrada para cuentas whats marcadas con nobotlog
                }
                $l_json = json_encode($data->message);
                $this->db->query("INSERT INTO `whatsapp_entry` (`id_contact`,
                    `id_user`, `id_session`, `json`, `message`, `datetime_received`,
                    `type`, `status`, `watype`, `caption`, `mimetype`, `size`,
                    `duration`, `lat`, `lng`, `thumb`, `url`, `id_wacta`)
                    values (?, ?, ?, ?, ?, now(), 'Entrante', 'Recibido', ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
                    array($cid, $ses->id_user, $ses->id, $l_json, $text,
                    $data->message->type, $caption, $mimetype, $size, $duration, $lat,
                    $lng, $thumb, $url, $wac->id)
                );
                $l_id = $this->db->insert_id();
                if ($ses->subtipo == 'Bot') {
                    $this->load->model("wabot_model");
                    if ($url != "") $textRec = $url;
                    $this->wabot_model->respondeBot($ses, $textRec);
                } elseif ($ses->subtipo == "Encuesta") {
                    $this->load->model("warate_model");
                    $this->warate_model->guardaencuesta($ses, $textRec);
                }
                // else, la sesión es con un agente, no requiere acción extra
            }
        }
    }

    public function entrante_chatapi($data, $wac) {
        $resp = ["error"=>"Data incorrecta"];
        list($tel, $ubi) = explode("@", $data->author);
        $contacto = (object)["name"=>$data->senderName,"uid"=>$tel];
        if ($cid = $this->valida_contacto($contacto, $wac->id)) {
            $textRec = $text = $data->body;
            $watype  = $data->type;
            if ($data->fromMe == true) {
                $reto = $this->getUltSesByTel($tel, $wac->id);
                $resp = $this->db->query("INSERT INTO `whatsapp_entry` (`id_contact`,
                    `id_user`, `id_session`, `json`, `message`, `datetime_received`,
                    `type`, `status`, `watype`, `id_wacta`)
                    values (?, ?, ?, ?, ?, now(), 'Saliente', 'Confirma', ?, ?)",
                    array($cid, $reto->id_user, $reto->id, json_encode($data), $text, $watype, $wac->id));
            } else {
                $ses = $this->creases(["cid"=>$cid,"wid"=>$wac->id,"tipo"=>"Entrante"]);
                if ($watype == 'location') {
                    $caption = $text;
                } else {
                    $caption = (!empty($data->caption)) ? $data->caption : "";
                }
                $mimetype = $size = $duration = $url = $lat = $lng = $thumb = "";
                if ($watype == 'location') list($lat, $lng) = explode(";", $text);
                if(in_array($watype, ['audio','media','ptt','image','video','document'])){
                    $finfo    = $this->getFile($text);
                    $mimetype = $finfo['mime'];
                    $size     = $finfo['size'];
                    $url      = $finfo['url'];
                    $thumb    = $finfo['thumb'];
                    if(in_array($watype, ['audio','media','ptt','video'])){
                        $duration = $this->getMediaDuration(FCPATH . 'whatsapprepository/' . $url);
                    }
                }
                if ($ses->subtipo == 'Bot' && !empty($wac->nobotlog)) {
                    $data->body = $text = "🙂"; // Quitar textos de registros de entrada para cuentas whats marcadas con nobotlog
                }
                $l_json = json_encode($data);
                $this->db->query("INSERT INTO `whatsapp_entry` (`id_contact`,
                    `id_user`, `id_session`, `json`, `message`,
                    `datetime_received`, `type`, `status`, `watype`, `caption`, `mimetype`, `size`,
                    `duration`, `lat`, `lng`, `thumb`, `url`, `id_wacta`)
                    values (?, ?, ?, ?, ?, now(), 'Entrante', 'Recibido', ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
                    array($cid, $ses->id_user , $ses->id, $l_json, $text, $watype, $caption,
                        $mimetype, $size, $duration, $lat, $lng, $thumb, $url, $wac->id)
                );
                if ($ses->subtipo == 'Bot') {
                    $this->load->model("wabot_model");
                    if ($url != "") $textRec = $url;
                    $this->wabot_model->respondeBot($ses, $textRec);
                } elseif ($ses->subtipo == "Encuesta") {
                    $this->load->model("warate_model");
                    $this->warate_model->guardaencuesta($ses, $textRec);
                }
                // else, la sesión es con un agente, no requiere acción extra
            }
        }

        return $resp;
    }

    public function actualizar($id, $data) {
        $status = "Enviado";
        $data = (is_array($data)) ? json_encode($data) : $data;
        if (strpos($data, "is not connected") || strpos($data, "Unauthorized") || strpos($data, "error")) {
            $status = "Error";
        }
        $this->db->query("UPDATE `whatsapp_entry` set `json` = ?, `status` = ?
            where `id` = ?", array($data, $status, $id));
        return $status;
    }

    public function creases($data) {
        if(empty($data["cid"]) || empty($data["wid"])) {
            return $this->db->query("INSERT INTO bago_log (`evento`, `data`, `fecha`) VALUES (?,?,NOW())", ["whatsapp_model creases", "Datos incompletos, no se crea sesión."]);
        }
        $cid   = $data["cid"];
        $wid   = $data["wid"];
        $tipo  = (empty($data["tipo"]))  ? "Saliente" : $data["tipo"];
        $flujo = (empty($data["flujo"])) ? "normal"   : $data["flujo"];
        // Verifica que no haya una sesion activa
        $query = $this->db->query("SELECT * from whatsapp_session
            WHERE id_contact = ? AND datetime_end IS NULL LIMIT 1", [$cid]
        );
        if ($query->num_rows() > 0) {
            $ret = $query->row();
        } else {
            $trcol = $trmar = "";
            $datar = [$cid, null, $wid, $tipo];
            if (!empty($data["trans"])) {
                $datar[] = $data["trans"];
                $trcol = ", `id_user_transfer`";
                $trmar = ", ?";
            }
            if ($tipo == 'Entrante') {
                if ($flujo == 'normal') {
                    // Valida que no haya un Bot activo
                    $query = $this->db->query("SELECT * FROM whatsapp_bot
                        WHERE id_wacta = ? AND active = 1", [$wid]
                    );
                    if ($query->num_rows()==1) {
                        $tipo = "Bot";
                        $datar[1] = '9999';
                        $datar[] = $tipo;
                        $datar[] = 0;
                        $trcol = ", `subtipo`, `paso`";
                        $trmar = ", ?, ?";
                    }
                }
            } elseif ($tipo == "Encuesta") {
                $datar[3] = "Saliente";
                $query = $this->db->query("SELECT `id_user`, `type` FROM whatsapp_session
                    WHERE id_contact = ? AND datetime_end > (NOW() - INTERVAL 2 MINUTE) ORDER BY id DESC LIMIT 1", [$cid]);
                $prevses = $query->row();
                if (!empty($prevses)) {
                    $datar[1] = $prevses->id_user;
                    $datar[3] = $prevses->type;
                }
                $datar[] = $tipo;
                $datar[] = 0;
                $trcol .= ", `subtipo`, `paso`";
                $trmar .= ", ?, ?";
            } else {
                $datar[1] = empty($data['uid']) ? ((empty($this->udata['id'])) ? "" : $this->udata['id']) : $data['uid'];
            }
            if ($tipo != "Entrante") {
                $this->db->query("INSERT INTO `whatsapp_session` (`id_contact`, `id_user`, `id_wacta`,
                    `datetime_received`, `datetime_assigned`, `datetime_start`, `type`$trcol)
                    values (?, ?, ?, now(), now(), now(), ?$trmar)", $datar
                );
                $sid = $this->db->insert_id();
            } else {
                $this->db->query("INSERT INTO `whatsapp_session` (`id_contact`, `id_user`, `id_wacta`,
                    `datetime_received`, `type`$trcol)
                    values (?, ?, ?, now(), ?$trmar)", $datar
                );
                // $this->db->query("INSERT INTO bago_log (`evento`, `data`, `fecha`) VALUES (?,?,NOW())", ["creases 445", $this->db->last_query() . " " . $this->db->error()]);
                $sid = $this->db->insert_id();
                $this->asignar_agente();
            }
            $this->whatsappfun->guardaVar(['cid'=>$cid,'var'=>'sid','val'=>$sid,'tip'=>'int','cam'=>'temporal']);
            $this->whatsappfun->guardaVar(['cid'=>$cid,'var'=>'ulIniSes','val'=>date("Y-m-d h:i:s")]);
            $query = $this->db->query("SELECT * FROM whatsapp_session WHERE id = ?", [$sid]);
            $ret = $query->row();
        }

        return $ret;
    }

    public function asignar_agente() {
        $asigned = 0;
        $query = $this->db->query("SELECT * FROM whatsapp_session WHERE id_user IS NULL");
        $porasig = $query->num_rows();
        if ($porasig > 0) {
            $seses = $query->result();
            foreach ($seses as $ses) {
                $agente = $this->datos_model->getAgenteDisponible('whatsapp', $ses->id_wacta);
                if ($agente) {
                    $this->db->query("UPDATE `whatsapp_contact` set `last_asigned_to` = ?
                        where `id` = ?", [$agente->id, $ses->id_contact]
                    );
                    $this->db->query("UPDATE `whatsapp_session` set `id_user` = ?, `datetime_assigned` = now()
                        where `id` = ?", [$agente->id, $ses->id]
                    );
                    $asigned++;
                }
            }
        }
        $ret = "WhatsApp por asignar: $porasig, asignados: $asigned\n";

        return $ret;
    }

    public function masivo_inicia($data) {
        $query = $this->db->query("INSERT INTO whatsapp_session
            (id_user, id_wacta, datetime_received, datetime_assigned, datetime_start,
            `type`, `message`) values (?, ?, now(), now(), now(), 'Masivo', ?)",
            [$this->session->userdata('uid'), $data['wid'], $data['watext']]);
        if ($query) {
            $sid = $this->db->insert_id();
            $respu = "Inicia envío masivo " . $sid;
        } else {
            $respu = "Error " . $this->db->error();
        }

        return $respu;
    }

    public function masivo_activo() {
        // Desactivado para evitar baneos
        // Reactivado con permisos por usuario, bajo riesgo del usuario
        $query = $this->db->query("SELECT id from whatsapp_session
            where type = 'Masivo' and datetime_end is null");

        return $query->num_rows();
    }

    public function masivo() {
        // Desactivado para evitar baneos
        // Reactivado con permisos por usuario, bajo riesgo del usuario
        $res = "No Masivos activos";
        $query = $this->db->query("SELECT `id`, `id_wacta`, `id_user`, `message`
            from `whatsapp_session` where `type` = 'Masivo' and `datetime_end` is null limit 1");
        if ($query->num_rows()==1) {
            $wases = $query->row();
            $query = $this->db->query("SELECT *
                from whatsapp_contact
                where id_wacta = ? AND id NOT IN
                (SELECT id_contact FROM whatsapp_entry WHERE id_session = ?)
                limit 20", [$wases->id_wacta, $wases->id]);
            if ($query->num_rows() > 0) {
                $filas = $query->result();
                $query = $this->db->query("SELECT * from `whatsapp_cuentas`
                    where `id` = ? and `active` = 1", [$wases->id_wacta]);
                $res = "Cuenta inactiva, reactivar para terminar masivo";
                if ($query->num_rows() > 0) {
                    $wacta = $query->row();
                    foreach ($filas as $row) {
                        $uno = $this->sale_texto(["ses"=>$wases, "watext"=>$wases->message, "cto"=>$row]);
                        // var_dump($uno);
                    }
                    $res = "Enviados " . count($filas) . " para masivo " . $wases->id;
                    if (count($filas)<20){
                        $this->db->query("UPDATE whatsapp_session set datetime_end = now(),
                            duration = TIME_TO_SEC(TIMEDIFF(NOW(), COALESCE(datetime_start, NOW())))
                            where id='$wases->id'");
                        $res = "Campaña terminada";
                    }
                }
            } else {
                $this->db->query("UPDATE whatsapp_session set datetime_end = now(),
                    duration = TIME_TO_SEC(TIMEDIFF(NOW(), COALESCE(datetime_start, NOW())))
                    where id='$wases->id'");
                $res = "Campaña terminada";
            }
        }

        return $res;
    }

    // Crea un condicional iniciado por AND para limitar los datos obtenidos de whatsapp_entry a la sesion en curso
    // TODO: Revisar esta parte
    private function conditional_history_query($id_contact, $id_wacta) {
        $sql = "";
        $w_historial_conv = in_array('wa_historial', $this->udata['permisoSec']);
        if( !$w_historial_conv ) {
            $sql = "INNER JOIN whatsapp_session ws ON ws.id = we.id_session AND ws.datetime_end IS NULL";
        }

        return $sql;
    }

    public function traer_asignacion() {
        $query = $this->db->query("SELECT was.id sid, was.id_wacta, wac.id, wac.name, wac.account
            from whatsapp_session was
            inner join whatsapp_contact wac on wac.id = was.id_contact
            where datetime_end is null and id_user = ? AND subtipo = ''",
            array($this->session->userdata('uid'))
        );

        return $query->result();
    }

    public function traer_data($data) {
        $uid = $this->session->userdata('uid');
        $query = $this->db->query("SELECT ws.*, concat(u.name,' ',u.last) usuario from whatsapp_session ws
            left join user u on u.id=ws.id_user where ws.id_contact = ? and ws.id_wacta = ?
            and ws.datetime_end is null limit 1", array($data['cid'], $data['wid']));
        if ($query->num_rows() == 1) {
            $sessi = $query->row();
            if ($sessi->subtipo != "") {
                return array("error" => "Contacto asignado a ".$sessi->subtipo);
            } elseif ($sessi->id_user == $uid) {
                $sid = $sessi->id;
            } else {
                return array("error" => "Contacto asignado a ".$sessi->usuario);
            }
        } else {
            $sid = 0;
        }
        $resp = ["lastid"=>0, "conver"=>"", "sid"=>$sid, "waminid"=>0];
        $toid = ($data['toid'] != 'false') ? "we.id < ".$data['toid']." AND" : "";
        $sql_cond_his = $this->conditional_history_query($data['cid'], $data['wid']);
        $query = $this->db->query("SELECT *
            from (SELECT we.id, we.message, we.type, we.status, we.watype, we.caption, we.mimetype, we.size, we.duration, we.lat, we.lng, we.thumb, we.url,
                DATE_FORMAT(we.datetime_received, '%e-%b %H:%i') received
                , CONCAT('traer_data:', we.id_session) AS id_session
                from whatsapp_entry we
                $sql_cond_his
                where $toid we.id_contact = ? and we.status<>'Confirma' and we.status<>'Error' and we.id_wacta = ? order by we.id DESC limit 20) tabla
            order by id ASC", [$data['cid'], $data['wid']]);
        if($query->num_rows()>0) {
            $resp = $this->conver($query->result());
            $resp['sid'] = $sid;
        }

        return $resp;
    }

    public function traer_masivos($data) {
        // Desactivado para evitar baneos
        // Reactivado con permisos por usuario
        $query = $this->db->query("SELECT ws.*, concat(u.name,' ',u.last) usuario
            from whatsapp_session ws
            left join user u on u.id=ws.id_user
            where ws.`type` = 'Masivo' and ws.id_wacta = ?", [$data['wid']]);
        $msgs = $query->result();
        $resconv = "";
        foreach ($msgs as $row) {
            $resconv .= '<div class="row justify-content-end"><div class="wamsg wamsgout">';
            $resconv .= "<strong>".$row->usuario.": </strong>".json_decode('"'.$row->message.'"');
            $resconv .= '<div class="watime"><small>'.$row->datetime_assigned.'</small></div></div></div>';
        }
        
        return array('conver' => $resconv);
    }

    public function traer_nuewa($data) {
        $resp = ["lastid"=>$data['lastid'], "conver"=>""];
        $sql_cond_his = $this->conditional_history_query($data['cid'], $data['wid']);
        $query = $this->db->query("SELECT we.*, DATE_FORMAT(we.datetime_received, '%e-%b %H:%i') received 
            from whatsapp_entry we
            $sql_cond_his
            where we.id_contact = ? and we.id > ? and we.id_wacta = ?
            and we.status <> 'Error' and we.status <> 'Por enviar' AND we.status <> 'Confirma'",
            array($data['cid'], $data['lastid'], $data['wid'])
        );
        if($query->num_rows()>0) {
            $conver = $query->result();
            $resp = $this->conver($conver);
        }
        return $resp;
    }

    public function terminases($data) {
        if (empty($data['sid']) || empty($data['cid'])) {
            return false;
        }
        $this->db->query("UPDATE whatsapp_entry set id_user = ?, status = 'Respondido', id_session = ?
            where id_contact = ? and type='Entrante' AND status = 'Recibido'",
            [$this->session->userdata('uid'), $data['sid'], $data['cid']]
        );
        $razon = (empty($data['razon'])) ? '' : $data['razon'];
        $res = $this->db->query("UPDATE whatsapp_session set `datetime_end` = now(),
            `datetime_start` = if(`datetime_start` is null, now(), `datetime_start`),
            `duration` = TIME_TO_SEC(TIMEDIFF(NOW(), COALESCE(`datetime_start`, NOW()))),
            `duration_wait` = TIME_TO_SEC(TIMEDIFF(coalesce(`datetime_start`, now()), `datetime_assigned`)),
            `message` = ?
            where `id` = ?", [$razon, $data['sid']]
        );
        if ($res) {
            $this->db->query("UPDATE whatsapp_cont_data SET temporal = '', secure = '' WHERE id_contact = ?", [$data['cid']]);
        }

        return $res;
    }

    public function save_wabox($data, $wac) {
        $data = json_encode($data);
        $this->db->query("INSERT INTO `whatsapp_hooks` (`json`, `datetime_received`) values (?, now())", array($data));

        return $this->entrante_wabox(json_decode($data), $wac);
    }

    public function save_chatapi($data, $wac) {
        $data = json_encode($data);
        $this->db->query("INSERT INTO `whatsapp_hooks` (`json`, `datetime_received`) values (?, now())", array($data));
        $msgs = json_decode($data);
        $res = true;
        if (!empty($msgs->messages)) {
            foreach ($msgs->messages as $msg) {
                $res = $this->entrante_chatapi($msg, $wac);
            }
        }

        return $res;
    }

    public function valida_cuenta($data) {
        $query = $this->db->query("SELECT * from `whatsapp_cuentas`
            where `cuenta` = ? or `idchatapi` = ? and `active` = 1 limit 1", [$data, $data]);

        return ($res = $query->row()) ? $res->id : false;
    }

    public function valida_contacto($data, $wid) {
        $res = false;
        $nombre = (strlen($data->name)>2) ? $data->name : $data->uid;
        $this->db->query("INSERT INTO `whatsapp_contact` (`account`, `name`, `datetime_register`, `id_wacta`)
            values (?, ?, now(), ?) ON DUPLICATE key UPDATE `name` = ?",
            array($data->uid, $nombre, $wid, $nombre)
        );
        $res = $this->db->insert_id();
        if (empty($res)) {
            $query = $this->db->query("SELECT id from `whatsapp_contact`
                where `account` = ? and `id_wacta` = ? limit 1",
                array($data->uid, $wid));
            $res = $query->row()->id;
        }

        return $res;
    }

    // Teléfono $tel y Whatsapp cuenta id $wid
    private function getUltSesByTel($tel = null, $wid = 0) {
        $query = $this->db->query("SELECT id from `whatsapp_contact`
            where `account` = ? and `id_wacta` = ? limit 1",
            array($tel, $wid));
        $query = $this->db->query("SELECT id, id_user FROM whatsapp_session
            WHERE id_contact = ? ORDER BY id DESC LIMIT 1", [$query->row()->id]);

        return $query->row();
    }

    public function buscacontacto($data) {
        $query = $this->db->query("SELECT * from whatsapp_contact
            WHERE (name like '%".$data['abuscar']."%' or account like '%".$data['abuscar']."%')
            AND (id_wacta=? or id_wacta is null)", [$data['wid']]);
        // Validamos si tiene permisos para crear contactos
        if( in_array('crearcontacwhatsbus', $this->udata['permisoSec']) ) {
            // Validamos si se encontraron resultados de busqueda
            if ($query->num_rows() == 0) {
                // Validamos que sea un numero de telefono
                if (is_numeric($data['abuscar'])) {
                    $nChar = strlen($data['abuscar']);
                    if( $nChar == 10 || $nChar == 13) {
                        // Formateamos el numero a 13 digitos
                        if( $nChar == 10 ) { $data['abuscar'] = "521".$data['abuscar']; }
                        $this->db->query("INSERT INTO `whatsapp_contact` (`id_wacta`, `account`, `name`, `datetime_register`)
                            values (?, ?, ?, now())", [ $data['wid'], $data['abuscar'], $data['abuscar']]
                        );
                        // Volvemos a consultar la busqueda
                        $query = $this->db->query("SELECT * from whatsapp_contact
                        WHERE (name like '%".$data['abuscar']."%' or account like '%".$data['abuscar']."%')
                        AND (id_wacta=? or id_wacta is null)", [$data['wid']]);
                    }
                }
            }
        }
        $respu = '<div class="pastilla">';
        $filas = '';
        foreach ($query->result() as $key => $row) {
            $filas .= '<p id="wac'.$row->id.'">
                <a class="waactivate" data-id="'.$row->id.'" data-sid="0" data-wac="'.
                $row->account.'" href="#">'.addslashes($row->name).'</a>
            </p>';
        }
        if (empty($filas)) {
            $respu .= '<p>Sin resultados</p></div>';
        } else {
            $respu .= $filas.'</div>';
        }

        return $respu;
    }

    public function whatsapp_detalle($data) {
        if (empty($data['cuenta'])) return $data;
        $maswere = (empty($data['wacto'])) ? "" : "AND we.id_contact = '$data[wacto]'";
        $data['prequery'] = "SELECT we.id_session 'sesión',
            date_format(we.datetime_received, '$this->dfor') fecha,
            time(we.datetime_received) hora,
            concat(u.name,' ', u.last) agente, wc.account contacto, wc.name nombre,
            `we`.`message` AS mensaje, we.watype tipo, we.type direccion, we.status estatus
            FROM whatsapp_entry we
            LEFT JOIN whatsapp_contact wc on wc.id=we.id_contact
            LEFT JOIN user u on u.id=we.id_user
            WHERE DATE(we.datetime_received) BETWEEN '$data[min]' AND '$data[max]'
            AND we.id_wacta='$data[cuenta]' AND u.id IN($data[agente]) $maswere
            AND we.status <> 'Confirma' ORDER BY we.id DESC, wc.name";
        $data = $this->datos_model->manejadorqueries($data);
        //Recorremos el resultado y sobre escribimos los valores de 2 columnas de ellos
        if( $data['pag'] !== 'x' ) { // WEB
            foreach($data['data'] as $index => $row) {
                $data['data'][$index]->mensaje = '<div class="truncate" style="max-width:200px" title="'.$row->mensaje.'">'.$row->mensaje.'</div>';
            }
        }

        return $data;
    }

    public function whatsapp_indicador($data) {
        if (empty($data['cuenta'])) return $data;
        $maswere = ($data['wacto']!="") ? "AND we.id_contact = '$data[wacto]'" : "";
        $data['prequery'] = "SELECT date_format(we.datetime_received, '$this->dfor') fecha,
            count(distinct(we.id_session)) sesiones,
            count(we.message) mensajes,
            COALESCE(sum(if(we.type='Entrante', 1, 0))) entrantes,
            COALESCE(sum(if(we.type='Saliente', 1, 0))) salientes
            FROM whatsapp_entry we
            LEFT JOIN user u on u.id=we.id_user
            WHERE we.status != 'Confirma' AND we.id_wacta='$data[cuenta]'
            AND DATE(we.datetime_received) BETWEEN '$data[min]'
            AND '$data[max]' AND u.id IN ($data[agente]) $maswere
            GROUP BY fecha ORDER BY date(we.datetime_received) DESC";
        $data['totales_query'] = "SELECT 'Totales:' AS 'tot',
            count(distinct(we.id_session)) sesiones,
            count(we.message) mensajes,
            COALESCE(sum(if(we.type='Entrante', 1, 0))) entrantes,
            COALESCE(sum(if(we.type='Saliente', 1, 0))) salientes
            FROM whatsapp_entry we
            LEFT JOIN user u on u.id=we.id_user
            WHERE we.status != 'Confirma' AND we.id_wacta='$data[cuenta]'
            AND DATE(we.datetime_received) BETWEEN '$data[min]'
            AND '$data[max]' AND u.id IN ($data[agente]) $maswere";
        return $this->datos_model->manejadorqueries($data);
    }

    public function whatsapp_sesion($data) {
        if (empty($data['cuenta'])) return $data;
        $maswere = ($data['wacto']!="") ? "AND ws.id_contact = '$data[wacto]'" : "";
        $data['prequery'] = "SELECT ws.id, wcta.id_campaign, ws.id 'sesión', date_format(ws.datetime_assigned, '$this->dfor') fecha,
            ifnull(wc.name,'') contacto, ifnull(wc.account,'') numero, ws.type tipo,
            CONCAT(u.name,' ', u.last) agente,
            ifnull(time(ws.datetime_assigned), '') asig,
            ifnull(time(ws.datetime_start),'') inicio,
            ifnull(time(ws.datetime_end),'') fin,
            sec_to_time(ws.duration_wait) espera,
            sec_to_time(ws.duration) duracion,
            (SELECT count(id) FROM whatsapp_entry WHERE id_session=ws.id and status <> 'Confirma') mensajes,
            IFNULL(ws.id_user_transfer, '') AS transfiere,
            IFNULL(cd.cal,'') 'calidad', IFNULL(cd.star,'') 'star', IFNULL(cc.comentario, '') comentario
            FROM whatsapp_session ws
            JOIN whatsapp_cuentas wcta ON wcta.id=ws.id_wacta
            LEFT JOIN whatsapp_contact wc ON wc.id=ws.id_contact
            LEFT JOIN user u ON u.id = ws.id_user
            LEFT JOIN (SELECT id_session, sum(value) 'cal', round((sum(value)-1)/20) 'star'
                FROM `whatsapp_quality_values` group by id_session) cd ON cd.id_session = ws.id
            LEFT JOIN (
                SELECT wqv.id_session, wqv.value 'comentario'
                FROM `whatsapp_quality_values` wqv
                LEFT JOIN quality_fields qf ON qf.id = wqv.id_quality_fields
                WHERE qf.question = 'Comentario'
                AND qf.weight = 0
                AND qf.num_order = 30
                group by id_session
            ) cc ON cc.id_session = ws.id
            WHERE ws.id_wacta='$data[cuenta]'
            AND DATE(ws.datetime_assigned) BETWEEN '$data[min]' AND '$data[max]'
            AND ws.id_user IN ($data[agente]) $maswere
            AND ws.id_user != '9999'
            ORDER BY ws.datetime_assigned DESC";
        $data = $this->datos_model->manejadorqueries($data);
        $calificar = in_array('calidad/guardareval', $this->udata['permiso']) ? true : false;
        if ($data['pag'] !== 'x') { // WEB
            foreach ($data["data"] as $key => $row) {
                $boton = "";
                if ($row->calidad != '') {
                    if ($row->calidad <= 69.4) {
                        $clase = "esrojo";
                    } elseif ($row->calidad <= 79.4) {
                        $clase = "esnaranja";
                    } elseif ($row->calidad <= 89.4) {
                        $clase = "esamarillo";
                    } else {
                        $clase = "esverde";
                    }
                    $vacias = 5 - $row->star;
                    for ($i = 0; $i < $row->star; $i++) {
                        $boton .= "<i class='fas fa-star ".$clase."'></i>";
                    }
                    for ($i = 0; $i < $vacias; $i++) {
                        $boton .= "<i class='far fa-star ".$clase."'></i>";
                    }
                    $data["data"][$key]->calidad = $row->calidad . "%";
                } else {
                    $boton = "<button type='button' class='btn btn-success lanzamodal' data-src='".
                    $row->star."' data-toggle='modal' data-target='#evalModal' data-id='".
                    $row->id."' data-cam='".$row->id_campaign."' data-cto='".$row->contacto." (".$row->numero.")'>Evaluación</button>";
                }
                $cursor = ($row->comentario == '') ? '' : "class='cursor-pointer'";
                $data["data"][$key]->calidad .= " <span ".$cursor." title='".$row->comentario."'>$boton</span>";
                unset($data["data"][$key]->star);
                unset($data["data"][$key]->comentario);
                
            }
        } else { // CSV
            foreach ($data["data"] as $key => $row) {
                unset($data["data"][$key]['star']);
            }
            // Agregamos el en encabezado "Comentario de calidad" al final, solo si es el reporte csv
            $data['campos'][] = 'Comentario de calidad';
        }
        //Recorremos los campos para eliminar el de star
        foreach($data['campos'] as $index => $row) {
            // Se borra de una el campo star y el siguiente que es el comentario, para no rehacer el ciclo
            if( $row == 'star')
                array_splice($data['campos'], $index, 2); 
        }

        $query = $this->db->query("SELECT
            sec_to_time(round(avg(ws.duration_wait))) espera,
            sec_to_time(round(avg(ws.duration))) duracion,
            round(avg((SELECT count(id) FROM whatsapp_entry
            WHERE id_session=ws.id and status <> 'Confirma'))) mensajes
            FROM whatsapp_session ws
            LEFT JOIN whatsapp_contact wc ON wc.id=ws.id_contact
            LEFT JOIN user u ON u.id = ws.id_user
            WHERE ws.datetime_end is not null AND DATE(ws.datetime_assigned)
            AND ws.id_wacta='$data[cuenta]' BETWEEN '$data[min]' AND '$data[max]'
            AND ws.id_user IN ($data[agente]) $maswere
            AND ws.id_user != '9999'
            ");
            // NO SE DEBE MOSTAR EN ESTA SESION LAS SESIONES DEL WHAP BOT ID_USER 9999
        $data['tot'] = $query->result();
        return $data;
    }

    public function whatsapp_reporte_global_sesion($data) {
        if (empty($data['cuenta']) || empty($data['min']) || empty($data['max'])) {
            return $data;
        }
        $data["data"] = [];
        $prequery = "SELECT ws.id 'ids',
            ws.datetime_received,
            ws.datetime_end,
            TIME(ws.datetime_end) 'fin',
            date_format(ws.datetime_received, '$this->dfor') 'Fecha',
            ifnull(wc.name, '') 'Contacto',
            ifnull(wc.account, '') 'Número',
            time(ws.datetime_start) 'Inicio',
            if(ws.id_user = '9999', 'Bot', 'Agente') 'Tipo'
            FROM whatsapp_session ws
            LEFT JOIN whatsapp_contact wc ON wc.id = ws.id_contact
            WHERE DATE(ws.datetime_received) BETWEEN '$data[min]' AND '$data[max]'
            AND ws.id_wacta='$data[cuenta]'
            AND ws.id_user_transfer is null
            ORDER BY ws.datetime_received DESC";
        $query = $this->db->query($prequery);
        $data["cuenta"] = $query->num_rows();
        if ($data['pag'] !== "x") {
            $query = $this->db->query($prequery . " limit $data[pag], $data[rpp]");
        }
        foreach ($query->result() as $row) {
            $sids = [$row->ids];
            $a = 'ini';
            $ulses = $row;
            while ($a != 'fin') {
                // id_user_transfer tiene el id de la sesión desde la que se transfiere
                $squery = $this->db->query("SELECT *, TIME(datetime_end) 'fin'
                    from whatsapp_session
                    where id_user_transfer = ?", end($sids));
                if ($squery->num_rows() == 1) {
                    $ulses = $squery->row();
                    $sids[] = $ulses->id;
                } else {
                    $a = 'fin';
                }
            }
            $row->ids = implode(",", $sids);
            $imseses = "'" . implode("','", $sids) . "'";
            $ssquery = $this->db->query("SELECT count(`id`) 'mensajes',
                IFNULL(TIMEDIFF(cast('" . $ulses->datetime_end .
                "' as datetime), cast('" . $row->datetime_received . "' as datetime)),'') duracion
                FROM whatsapp_entry
                WHERE id_session in ($imseses) AND status <> 'Confirma'");
            $totmsgs = $ssquery->row();
            $row->Fin = $ulses->fin;
            $row->Duración = $totmsgs->duracion;
            $row->Mensajes = $totmsgs->mensajes;
            $data['data'][] = [
                'ids'      => $row->ids,
                'Fecha'    => $row->Fecha,
                'Contacto' => $row->Contacto,
                'Número'   => $row->Número,
                'Tipo'     => $row->Tipo,
                'Inicio'   => $row->Inicio,
                'Fin'      => $row->Fin,
                'Duración' => $row->Duración,
                'Mensajes' => $row->Mensajes,
            ];
        }
        $data['campos'] = ['ids','Fecha','Contacto','Número','Tipo','Inicio','Fin','Duración','Mensajes'];
        
        return $data;
    }

    // Gateway log
    public function gwlog($post, $va) {
        $tel = (!empty($post['uid'])) ? $post['uid'] : $post['instanceId'];
        $this->db->query("INSERT INTO `whatsapp_gateway` (`queviene`, `dest_tel`, `dest_ip`, `hora`)
            values (?,?,?,now())", array(json_encode($post, true), $tel, $va));

        return $this->db->insert_id();
    }

    // Actualiza gateway log
    public function updResp($data) {
        return $this->db->query("UPDATE `whatsapp_gateway` set `dest_resp`='" .
            $data['resp'] . "' where id='" . $data['id'] . "'");
    }

    public function getWaDestIp($idcaotoken) {
        // Instance Id de Chatapi o Token wabox
        $query = $this->db->query("SELECT `ip` from `whatsapp_serve`
            where `activo` = '1' and (`numero` = ? || `idchatapi` = ?)", [$idcaotoken, $idcaotoken]);
        if ($query->num_rows() == 1) {
            return $query->row()->ip;
        }

        return false;
    }

    public function guardarCta($data) {
        $uid = $this->session->userdata('uid');
        $this->db->query("INSERT INTO `whatsapp_cuentas` (`id`, `id_campaign`, `idchatapi`, `cuenta`,
            `nombre`, `token`, `active`, `almacen`, `alta_quien`, `alta_cuando`) values (?,?,?,?,?,?,1,?,'$uid',now())
            ON DUPLICATE KEY UPDATE `id_campaign`=?, `idchatapi`=?, `cuenta`=?, `nombre`=?, `token`=?, `active`=?, `almacen`=? ",
            array($data['id'], $data['cam'], $data['cha'], $data['num'], $data['nom'], $data['tok'], $data['alm'],
            $data['cam'], $data['cha'], $data['num'], $data['nom'], $data['tok'], $data['act'], $data['alm'])
        );
        $data['id'] = ($this->db->insert_id()) ? $this->db->insert_id() : $data['id'];
        return $data;
    }

    private function get_video_attributes($video) {
        $output = shell_exec("ffmpeg -i ".$video." -vstats 2>&1");
        $regex_sizes = "/Video: ([^,]*), ([^,]*), ([0-9]{1,4})x([0-9]{1,4})/"; // or : $regex_sizes = "/Video: ([^\r\n]*), ([^,]*), ([0-9]{1,4})x([0-9]{1,4})/"; (code from @1owk3y)
        if (preg_match($regex_sizes, $output, $regs)) {
            $codec = $regs [1] ? $regs [1] : null;
            $width = $regs [3] ? $regs [3] : null;
            $height = $regs [4] ? $regs [4] : null;
        }
        $regex_duration = "/Duration: ([0-9]{1,2}):([0-9]{1,2}):([0-9]{1,2}).([0-9]{1,2})/";
        if (preg_match($regex_duration, $output, $regs)) {
            $hours = $regs [1] ? $regs [1] : null;
            $mins = $regs [2] ? $regs [2] : null;
            $secs = $regs [3] ? $regs [3] : null;
            $ms = $regs [4] ? $regs [4] : null;
        }
        $video = array(
            'codec'    => $codec,
            'width'    => $width,
            'height'   => $height,
            'hours'    => $hours,
            'mins'     => $mins,
            'secs'     => $secs,
            'ms'       => $ms,
            'duration' => $regex_duration
        );

        return $video;
    }

    private function getFile($file, $para = 'c') { // c = chatapi, w = wabox
	    ini_set('allow_url_fopen', 'on');
        $subdir   = date("Y") . '/' . date("m") . '/';
        $dir      = FCPATH . 'whatsapprepository/' . $subdir;
        $nuname   = str_replace('.','',(string)microtime(true));
        $partes   = explode(".", $file);
        $ext      = "." . strtolower(end($partes));
        $filename = $nuname . $ext;
        $url      = $subdir . $filename;
        $nurl     = $dir . $filename;
        if(!is_dir($dir)) {
            mkdir($dir, 0777, true);
        }
        $timelapse = 10000;
	    $counter=0;
        do {
        	if($counter>=$timelapse) {continue;}
        	$file = file_get_contents($file);
        	sleep(1);
        	$counter++;
        } while(strlen($file) == 0);
        file_put_contents($nurl, $file);
        if ($para == 'w') { // Si es wabox ya trae la data del archivo
            return $url;
        }
        $mime = mime_content_type($nurl);
        $size = filesize($nurl);
        $this->load->helper('thumb_helper');

        return ["mime"=>$mime, "size"=>$size, "url"=>$url, "thumb"=>createThumb($nurl)];
    }

    private function getMediaDuration($media) {
        require_once(APPPATH . 'third_party/vendor/getid3/getid3.php'); // https://www.getid3.org/
        $getID3 = new getID3;
        $thisFileInfo = $getID3->analyze($media);

        return ceil($thisFileInfo['playtime_seconds']);
    }

    public function transferir($data) {
        $sid = (empty($data['sid'])) ? '' : $data['sid'];
        $nag = (empty($data['nag'])) ? '' : $data['nag'];
        if(empty($sid) || empty($nag)) return array("error"=>"Que intentas?");
        $query = $this->db->query("SELECT * from whatsapp_session
            WHERE id = ? AND datetime_end IS NULL", [$sid]);
        if($query->num_rows()<1) return array("error"=>"Datos incorrectos en la sesión.");
        $antses = $query->row();
        $this->terminases(["sid"=>$sid,"cid"=>$antses->id_contact,"razon"=>"Transfer"]);
        $query = $this->db->query("INSERT INTO `whatsapp_session` (`id_contact`, `id_user`, `id_wacta`,
            `datetime_received`, `datetime_assigned`, `type`, `id_user_transfer`) values (?, ?, ?, now(), now(), ?, ?)",
            array($antses->id_contact, $nag, $antses->id_wacta, $antses->type, $antses->id_user)
        );
        $salida = true;
        // if($query->affected_rows()<1) {
        //     $salida = array("error"=>"Error de asignación al nuevo agente.");
        // }
        return $salida;
    }

    public function wa_contactos($wid) {
        $query = $this->db->query("SELECT * from `whatsapp_contact`
            where `id_wacta` = '" . $wid . "' order by `name`, `account` limit 100");
        $res = "";
        foreach ($query->result() as $key => $row) {
            $res .= '<p id="wac'.$row->id.'" class="wacontact" data-account="' .
                $row->account . '"><a class="waactivate" data-id="' . $row->id .
                '" data-sid="0" data-account="' . $row->account . '" href="#"><pre>' .
                addslashes(htmlspecialchars($row->name)).'</pre></a></p>';
        }
        return $res;
    }

    public function getWaData($id=0) {
        if($id == 0) return false;
        $query = $this->db->query("SELECT * from whatsapp_cuentas where id=? and active='1'", array($id));

        return $query->row();
    }

    private function decodeEmoticons($src) {
        $replaced = preg_replace("/\\\\u([0-9A-F]{1,4})/i", "&#x$1;", $src);
        $result = mb_convert_encoding($replaced, "UTF-16", "HTML-ENTITIES");
        $result = mb_convert_encoding($result, 'utf-8', 'utf-16');
        return $result;
    }

    private function conver($conver, $lastid = 0) {
        $resconv = "";
        $waminid = 0;
        $row     = (object)["id"=>0];
        foreach ($conver as $row) {
            if (($row->id > 0 && $waminid == 0) || $row->id < $waminid) $waminid = $row->id;
            if ($row->type == 'Entrante') {
                $inout = "wamsgin";
                $justy = "";
                $url = (strpos($row->url,'whatsapprepository/') !== false) ? site_url($row->url) : site_url('whatsapprepository/' . $row->url);
            } else {
                $inout = "wamsgout";
                $justy = "justify-content-end";
                $url = site_url('wafiles/'.$row->url);
            }
            $src = (!empty($row->thumb) && substr($row->thumb, 0, 4) != "data") ?
                'data:image/png;base64,' . $row->thumb : $row->thumb;
            $thumb = (!empty($row->thumb)) ? '<img style="max-height:100px;" alt="' .
                $row->caption.'" src="' . $src . '">' : (!empty($this->b64imgs[$row->watype]) ?
                '<img style="max-height:100px;" alt="' .
                    $row->caption . '" src="' . $this->b64imgs[$row->watype] . '">' : 'Sin miniatura');
            $resconv .= '<div class="row '.$justy.'"><div class="wamsg '.$inout.'">';
            switch ($row->watype) {
                case 'location':
                    $url = "https://www.google.com/maps/search/".
                        $row->lat."+".$row->lng."/@".$row->lat.",".$row->lng."z";
                case 'document':
                case 'media':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" href="' . $url .
                        '" target="_blank" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'ptt':
                case 'audio':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" class="verenmodal" data-tipo="audio" href="' . $url .
                        '" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'sticker':
                case 'image':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" class="verenmodal" data-tipo="image" href="' . $url .
                        '" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'video':
                    $dura = $row->duration;
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption.'" href="'.$url.'" target="_blank" style="max-heght:100px">' .
                        $thumb . '</a><br>' . '<div>' . $dura . '</div>';
                    break;
                case 'vcard':
                    $resconv .= '<span style="color:darkred;"><i class="fas fa-radiation-alt">
                        vCard, no se muestra información !</i></span><br>';
                    break;
                default:
                    if (strpos($row->message, "\\") !== false) {
                        $resconv .= addslashes(nl2br($this->decodeEmoticons($row->message)));
                    } else {
                        $resconv .= addslashes(nl2br($row->message));
                    }
                    break;
            }
            $resconv .= '<div class="watime"><small>'.$row->received.'</small></div></div></div>';
        }
        return ["lastid"=>$row->id, "conver"=>$resconv, "waminid"=>$waminid];
    }

    public function calidad_traer_data($data) {
        $sid = 0;
        // Definimos la respuesta vacia
        $resp = [
            'conver' => '', 
            'current_session' => -1, 
        ];
        // Consultamos la session
        // En caso de ser 0, traemos la ultima
        $current_session= $data['current_session'];
        $id_contacto    = $data['cid'];
        $id_cuenta      = $data['wc'];
        $id_agente      = $data['id_agente'];
        $min            = $data['min'];
        $max            = $data['max'];
        $sql_comp = '';
        if( $data['current_session'] > 0 ) {
            $sql_comp = "AND id < $current_session"; 
        }
        $row = $this->db->query("SELECT id
        FROM whatsapp_session ws
        WHERE ws.id_wacta = ?
        AND ws.id_contact = ?
        AND ws.id_user = ?
        AND ws.datetime_start BETWEEN ? AND ?
        $sql_comp
        ORDER BY id DESC
        LIMIT 1", [$id_cuenta, $id_contacto, $id_agente, $min.' 00:00:00', $max.' 23:59:59'])->row();
        if( $row ) {
            $id_session = $row->id;
        } else {
            return $resp;
        }
        $toid = '';
        $query = $this->db->query("SELECT *
            FROM (
                SELECT we.id, we.message, we.type, we.status, we.watype, we.caption, we.mimetype, we.size, we.duration, we.lat, we.lng, we.thumb, we.url,
                    DATE_FORMAT(we.datetime_received, '%e-%b %H:%i') received, 
                    CONCAT('traer_data:', we.id_session) AS traer_data,
                    wmr.id AS id_wa_message_rating, wmr.rating, wmr.comment,
                    we.id_session, DATE_FORMAT(ws.datetime_start, '%e-%b %H:%i') AS datetime_start, ws.datetime_end,
                    wc.id_campaign, cse.calif_session
                FROM whatsapp_entry we
                LEFT JOIN whatsapp_message_rating wmr ON wmr.id_whatsapp_entry = we.id
                LEFT JOIN (
                    SELECT qv.id_session, SUM(qv.value) AS calif_session
                    FROM whatsapp_quality_values qv
                    INNER JOIN quality_fields qf ON qf.id = qv.id_quality_fields
                    WHERE (qf.question != 'Comentario' OR qf.num_order != 30)
                    GROUP BY id_session
                ) cse ON cse.id_session = we.id_session
                INNER JOIN whatsapp_session ws ON ws.id = we.id_session
                INNER JOIN whatsapp_cuentas wc ON ws.id_wacta = wc.id 
                WHERE $toid we.id_contact = ?
                    AND we.status<>'Confirma'
                    AND we.status<>'Error'
                    AND we.id_wacta = ?
                    AND ws.id = $id_session 
                ORDER BY we.id DESC
            ) tabla
            ORDER BY id ASC",
            [$data['cid'], $data['wc']]
        );
        if($query->num_rows()>0) {
            $resp = $this->calidad_conver($query->result(), 0);
            $resp['sid'] = $sid;
            $resp['current_session'] = $id_session;
            $resp['query'] = $this->db->last_query();
        }

        return $resp;
    }

    private function calidad_conver($conver, $lastid = 0) {
        $resconv = "";
        $waminid = 0;
        $id_session_ant = 0;
        foreach ($conver as $row) {
            $btn_cal_msg = '';
            $html_id_msg = 'msg_'.$row->id;
            if( $row->type == 'Saliente' ) {
                if( $row->id_wa_message_rating === null ) {
                    $btn_cal_msg = '
                    <div class="px-2 mt-n2 mb-3">
                        <button type="button" class="btn btn-primary btn-sm" onclick="cw.calificarMsg('.$row->id.')">
                            Calificar
                        </button>
                    </div>';
                } else {
                    $btn_cal_msg = '
                    <div class="px-2 mt-n2 mb-3 bg-secondary">
                        Calificación: '.html_rating($row->rating, 5).'
                        <br/><i>'.$row->comment.'</i>
                    </div>';
                }
            }
            $id_session = $row->id_session;
            if( $id_session != $id_session_ant ) {
                $current_session = ( $row->datetime_end != null  ) ? '' : 'En curso...';
                $btn_cal_ses = '<div
                    class="border-bottom border-top border-2 mt-2 text-primary cursor-pointer"
                    onclick="cw.calificarSes('.$row->id_campaign.', '.$row->id_session.')"
                >
                    Calificar
                </div>';
                if( $row->calif_session != NULL ) {
                    $btn_cal_ses = '<span class="text-primary">Calificacion: '.$row->calif_session.'%</span>';
                }
                $row_session = '
                <div id="row-cses-'.$row->id_session.'" class="row justify-content-center">
                    <div class="bg-white border rounded text-secondary mt-3 mb-2 px-2 text-center">
                        Conversación '.$current_session.'<br/>'.$row->datetime_start.' <br/>
                        <div id="btn-cses-'.$row->id_session.'">
                            '.$btn_cal_ses.'
                        </div>
                    </div>
                </div>
                ';
                $id_session_ant = $id_session;
            } else {
                $row_session = '';
            }
            ///////////////////////////
            if (($row->id > 0 && $waminid == 0) || $row->id < $waminid) $waminid = $row->id;
            if ($row->type == 'Entrante') {
                $inout = "wamsgin";
                $justy = "";
                $url = (strpos($row->url,'whatsapprepository/') !== false) ? site_url($row->url) : site_url('whatsapprepository/' . $row->url);
            } else {
                $inout = "wamsgout";
                $justy = "justify-content-end";
                $url = site_url('wafiles/'.$row->url);
            }
            $src = (!empty($row->thumb) && substr($row->thumb, 0, 4) != "data") ?
                'data:image/png;base64,' . $row->thumb : $row->thumb;
            $thumb = (!empty($row->thumb)) ? '<img style="max-height:100px;" alt="' .
                $row->caption.'" src="' . $src . '">' : (!empty($this->b64imgs[$row->watype]) ?
                '<img style="max-height:100px;" alt="' .
                    $row->caption . '" src="' . $this->b64imgs[$row->watype] . '">' : 'Sin miniatura');
            $resconv .= $row_session.'<div class="row '.$justy.'"><div id="'.$html_id_msg.'" class="wamsg '.$inout.'">';
            switch ($row->watype) {
                case 'location':
                    $url = "https://www.google.com/maps/search/".
                        $row->lat."+".$row->lng."/@".$row->lat.",".$row->lng."z";
                case 'document':
                case 'media':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" href="' . $url .
                        '" target="_blank" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'ptt':
                case 'audio':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" class="verenmodal" data-tipo="audio" href="' . $url .
                        '" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'sticker':
                case 'image':
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption . '" class="verenmodal" data-tipo="image" href="' . $url .
                        '" style="max-heght:100px">'.$thumb.'</a><br>';
                    if ($row->caption != "NoCap") {
                        $resconv .= '<br><p>' . $row->caption . '</p>';
                    }
                    break;
                case 'video':
                    $dura = $row->duration;
                    $resconv .= '<a data-toggle="tooltip" data-placement="right" title="' .
                        $row->caption.'" href="'.$url.'" target="_blank" style="max-heght:100px">' .
                        $thumb . '</a><br>' . '<div>' . $dura . '</div>';
                    break;
                case 'vcard':
                    $resconv .= '<span style="color:darkred;"><i class="fas fa-radiation-alt">
                        vCard, no se muestra información !</i></span><br>';
                    break;
                default:
                    if (strpos($row->message, "\\") !== false) {
                        $resconv .= addslashes(nl2br($this->decodeEmoticons($row->message)));
                    } else {
                        $resconv .= addslashes(nl2br($row->message));
                    }
                    break;
            }
            $resconv .= '<div class="watime"><small>'.$row->received.'</small></div>
            </div></div>
            <div id="row-cmsg-'.$row->id.'" class="row justify-content-end">
                '.$btn_cal_msg.'
            </div>';
        }
        return ["lastid"=>$row->id, "conver"=>$resconv, "waminid"=>$waminid];
    }

    public function delDupliWAContact() {
        $query = $this->db->query("SELECT `id_wacta`, `account`
            FROM `whatsapp_contact`
            GROUP BY `id_wacta`, `account`
            HAVING COUNT(`account`) > 1 limit 50");
        $dup = $query->result();
        foreach ($dup as $key => $row) {
            $query = $this->db->query("SELECT `id` from `whatsapp_contact`
                where `id_wacta` = '$row->id_wacta' AND `account` = '$row->account' order by `id`");
            $rows   = $query->result();
            $pmay   = array_pop($rows);
            $may    = $pmay->id;
            $tochan = "";
            foreach ($rows as $sk => $sr) {
                $tochan .= $sr->id.",";
                echo "A cambiar: " . $sr->id . ", por: " . $may . "<br />\n";
            }
            $tochan = rtrim($tochan, ',');
            echo "tochan: " . $tochan . "<br />\n";
            $query = $this->db->query("UPDATE `whatsapp_session` set `id_contact` = '$may'
                where `id_contact` in ($tochan) and `id_wacta` = '$row->id_wacta'");
            echo "query ses: " . $query . "<br />\n";
            if(!$query) return var_dump($this->db->error());
            $query = $this->db->query("UPDATE IGNORE `whatsapp_entry` set `id_contact` = '$may'
                where `id_contact` in ($tochan) and `id_wacta` = '$row->id_wacta'");
            echo "query entry: " . $query . "<br />\n";
            if(!$query) return var_dump($this->db->error());
            $query = $this->db->query("DELETE FROM `whatsapp_contact` where id in ($tochan)");
            if(!$query) return var_dump($this->db->error());
        }
        $query = $this->db->query("ALTER TABLE `whatsapp_contact`
            ADD UNIQUE `id_wacta_account` (`id_wacta`, `account`)");
        if (!$query) {
            return var_dump($this->db->error());
        } else {
            return "Terminado exitosamente!";
        }
    }

    function traersesconv($data) {
        $query = $this->db->query("SELECT we.*,
            DATE_FORMAT(datetime_received, '%e-%b %H:%i') received
            , CONCAT('traer_data:', we.id_session) AS id_session
            from whatsapp_entry we
            where we.id_session = ? and we.status<>'Confirma' and we.status<>'Error'",
            [$data['sid']]);
        $res = $query->result();
        $resp = $this->conver($res);
        $resp['session'] = $this->get_data_session_modal($data['sid']);

        return $resp;
    }

    private function get_data_session_modal($id_session) {
        $query = $this->db->query("SELECT DATE_FORMAT(ws.datetime_assigned, '$this->dfor') fecha, IFNULL(TIME(ws.datetime_start),'') inicio,
        CONCAT(u.name,' ', u.last) agente, IFNULL(wc.account,'') numero
        FROM whatsapp_session ws
        INNER JOIN user u ON ws.id_user = u.id
        LEFT JOIN whatsapp_contact wc ON wc.id=ws.id_contact
        WHERE ws.id = ?", [$id_session]);

        return $query->row();
    }

    private $b64imgs = [
        'location'=>'data:image/jpeg;base64,',
        'ptt'=>'data:image/jpeg;base64,',
        'audio'=>'data:image/jpeg;base64,',
        'image'=>'data:image/png;base64,',
        'document'=>'data:image/jpeg;base64,',
        'video'=>'data:image/jpeg;base64,',
    ];

}
