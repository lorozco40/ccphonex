    public function tickets_detalle($data) {
        if($this->db->table_exists('formd_'.$data['formulario'].'_crm')) {
            $maswere  = "date(f.apertura) between '" . $data['min'] . "' and '" . $data['max'] . "'";
            $maswere .= (empty($data['bus']))     ? "" : " AND f.id = '" . $data['bus'] . "'";
            $maswere .= (empty($data['estatus'])) ? "" : " AND f.estatus = '" . $data['estatus'] . "'";
            $prequery = "SELECT f.id TicketID, COALESCE(CONCAT(ua.name,' ',ua.last),'') Asignado,
                f.apertura Apertura, COALESCE(f.estatus,'') 'Estatus actual',
                m.fecha 'Mov fecha', concat(u.name, ' ', u.last) 'Mov Usuario', m.estatus 'Mov Estatus',
                COALESCE(IF(LENGTH(m.comentario)>30,CONCAT(SUBSTRING(m.comentario,1,30),'...'),m.comentario),'') Comentario
                FROM formd_".$data['formulario']." f LEFT JOIN user ua on ua.id = f.asignar_a
                LEFT JOIN formd_".$data['formulario']."_crm m on m.id_formd = f.id
                LEFT JOIN user u on u.id=m.id_user where ".$maswere." order by f.id, m.fecha";
            $query = $this->db->query($prequery);
            $data['cuenta'] = $query->num_rows();
            $data['campos'] = $query->list_fields();
            if ($data['pag'] === "x") {
                $data['data'] = $query->result_array();
                return $data;
            }
            $limites = " limit ".$data['pag'].", ".$data['rpp'];
            $query = $this->db->query($prequery . $limites);
            $data["data"] = $query->result();

            return $data;
        }

        return $data;
    }

    public function cron() {
        $query = $this->db->query("SELECT cl.*, f.id_campaign
            FROM crm_light cl
            JOIN form f ON f.id = id_form
            WHERE cl.active = 1"
        );
        $ret = "Semáforos activos: " . $query->num_rows();
        $crmSemRows = $query->result();
        $tickact = 0;
        //Consultamos los horarios de las campañas encontradas
        $campaigns = [0];
        foreach ($crmSemRows as $form) {
            if( $form->campaign_hours == 1 )
                $campaigns[] = $form->id_campaign;
        }
        $campaigns = array_unique($campaigns);
        $campaigns = implode(',', $campaigns);
        //Consultamos los horarios de las campañas que tienen formularios con semaforo activo
        $horarios = $this->db->query('SELECT * FROM campaign_hour WHERE id_campaign IN ('.$campaigns.')')->result();
        //Se recorren todos los crm con semaforo activo que tengan activado el semaforo 
        foreach ($crmSemRows as $crmsem) {
            //Validamos que la tabla formd_# tenga el campo semaforo, de lo contrario se lo agregamos
            if (!$this->db->field_exists('semaforo', 'formd_' . $crmsem->id_form)) {
                $data = array('id_form'=>$crmsem->id_form, 'type'=>'text', 'name'=>'Semáforo',
                    'values'=>'', 'depend'=>'0', 'order'=>'0');
                $this->load->model("form_model");
                $this->form_model->createc($data);
                echo "CRM no tenía campo semáforo, agregado.\n";
            }
            $query2 = $this->db->query("SELECT lf.*, u.user AS infoamail,
                TIMESTAMPDIFF(MINUTE, lf.apertura, NOW()) AS antiq FROM formd_" . $crmsem->id_form .
                " AS lf LEFT JOIN user u ON u.id = lf.asignar_a
                WHERE lf.cierre IS NULL AND lf.asignar_a > 0 AND lf.asignar_a IS NOT NULL");
            $tickact += $query2->num_rows();
            $tickets = $query2->result();
            foreach ($tickets as $ticket) {
                if( $crmsem->campaign_hours == 1 ) {
                    $minutos = $this->calc_campaign_hours($crmsem, $ticket, $horarios);
                    $ticket->antiq = $minutos;
                }
                //Si, tiempo a naranja existe y ticket->semaforo esta en blanco
                if ($crmsem->time_to_warn >= 1 && empty($ticket->semaforo) && $ticket->antiq >= $crmsem->time_to_warn &&
                    $ticket->antiq < $crmsem->time_to_red) {
                    $this->db->query("UPDATE formd_" . $crmsem->id_form . " SET semaforo = 'amarillo' WHERE id = '" .
                        $ticket->id . "'");
                    if ($crmsem->notify_warn) {
                        $this->pasasem($ticket, $crmsem, "amarillo");
                    }
                } elseif ($ticket->semaforo != "rojo" && $crmsem->time_to_red >= 1
                    && $ticket->antiq >= $crmsem->time_to_red) {
                    $this->pasasem($ticket, $crmsem, "rojo");
                }
                if ( $ticket->antiq > 0
                    && $crmsem->time_to_step >= 1
                    && abs($ticket->antiq - $crmsem->time_to_red) > 5
                    && abs($ticket->antiq - $crmsem->time_to_warn) > 5
                    && $crmsem->notify_step == 1
                    && ($crmsem->notify_step_after_red == 0 || $ticket->antiq > $crmsem->time_to_red)
                    && fmod($ticket->antiq, $crmsem->time_to_step) == 0) {
                    $this->notisem($ticket, $crmsem->id_form, $crmsem->msg_step);
                }
            }
        }
        $ret .= ", Tickets activos: " . $tickact;

        return $ret;
    }

    public function calc_campaign_hours($crm, $ticket, $horarios = []) {
        $apertura = $ticket->apertura;
        $now = date('Y-m-d H:i:s');
        // Inicializamos el tiempo total en minutos en 0
        $totalMin = 0;
        // Convertimos las fechas de apertura y now a objetos de tiempo
        $DTFechaApertura = new DateTime($apertura);
        $DTFechaNow = new DateTime($now);
        // Iteramos desde la fecha de apertura hasta la fecha actual
        $DTCurrentDay = clone $DTFechaApertura;
        while ($DTCurrentDay <= $DTFechaNow) {
            $diaSemana = intval($DTCurrentDay->format('w')) + 1;//día de la semana de la fecha actual (0 para domingo, 6 para sabado)
            //Obtenemos el Horario de esa fecha
            $horario_actual = false;
            foreach ($horarios as $row) {
                if ($row->dia == $diaSemana && $row->id_campaign == $crm->id_campaign) {
                    $horario_actual = $row;
                    break;
                }
            }
            //Si tiene fecha de inicio y fecha de fin, entonces es dia laboral, calcularemos el tiempo transcurrido en ese dia
            $hora_ini = false;
            $hora_fin = false;
            //Existe un horario
            if( $horario_actual !== false && !empty($horario_actual->inicio) && !empty($horario_actual->fin) ) {
                //CALCULAMOS LA HORA DE FIN
                if( $DTCurrentDay->format('Y-m-d') == $DTFechaNow->format('Y-m-d') ) {//Entonces evaluaremos hasta donde finalizar
                    $DTCurrentDayHorarioFin = new DateTime( $DTCurrentDay->format('Y-m-d').' '.$horario_actual->fin );
                    if ( $DTFechaNow > $DTCurrentDayHorarioFin ) {
                        $hora_fin = $horario_actual->fin;
                    } else {
                        $hora_fin = $DTFechaNow->format('H:i:s');
                    }
                } else {
                    $hora_fin = $horario_actual->fin;
                }
                //CALCULAMOS LA HORA DE INICIO
                if( $DTFechaApertura->format('Y-m-d') == $DTCurrentDay->format('Y-m-d') ) {//Entonces evaluaremos desde donde iniciar
                    $DTCurrentDayHorarioIni = new DateTime( $DTCurrentDay->format('Y-m-d').' '.$horario_actual->inicio );
                    if( $DTFechaApertura > $DTCurrentDayHorarioIni ) {
                        $hora_ini = $DTFechaApertura->format('H:i:s');
                    } else {
                        $hora_ini = $horario_actual->inicio;
                    }
                } else {
                    $hora_ini = $horario_actual->inicio;
                }
            }
            //En caso de que haya un fecha de inicio y una de fin para ese día, procedemos con el calculo
            $diferencia = null;
            $minutosDia = 0;
            if( $hora_ini !== false && $hora_fin !== false) {//Calculamos el tiempo de ese dia
                $DTFechaI = new DateTime($DTCurrentDay->format('Y-m-d').' '.$hora_ini);
                $DTFechaF = new DateTime($DTCurrentDay->format('Y-m-d').' '.$hora_fin);
                if( $DTFechaI < $DTFechaF ) {
                    $diferencia = $DTFechaI->diff($DTFechaF);
                    $minutosDia = ($diferencia->i)+($diferencia->h * 60);
                    $totalMin = $totalMin + $minutosDia;
                }
            }
            //Incrementamos un día
            $DTCurrentDay->modify('+1 day');
            $DTCurrentDay->setTime(0, 0, 0);
        }

        return $totalMin;
    }

    private function pasasem(stdClass $ticket, stdClass $sem, string $target) {
        echo "Ticket " . $ticket->id . " pasa a " . $target;
        $this->db->query("UPDATE formd_" . $sem->id_form . " SET semaforo = '$target' WHERE id = '$ticket->id'");
        if ($target == "amarillo") {
            $not = $sem->notify_warn;
            $msg = $sem->msg_warn;
        } elseif ($target == "rojo") {
            $not = $sem->notify_red;
            $msg = $sem->msg_red;
        } else {
            return;
        }
        if (!empty($not) && !empty($msg) && !empty($ticket->infoamail)) {
            $this->notisem($ticket, $sem->id_form, $msg);
        }
    }

    private function notisem(stdClass $ticket, int $fid, string $msg) {
        echo "Ticket " . $ticket->id . " del formulario " . $fid . " por notificar " . $msg;
        $data = ["id"=>$ticket->id, "fid"=>$fid, "enviara"=>[$ticket->infoamail], "adi"=>$msg];
        $this->informar($data);
    }

    public function actualizarCuentaEmail($data) {
        $IdEmailCount = null;
        if( !empty($data['id_email_account']) && $data['id_email_account'] != "" && $data['id_email_account'] > 0 ) $IdEmailCount = $data['id_email_account'];
        return $this->db->query("UPDATE `form` set `id_email_account` = ? where `id` = ?",
            array($IdEmailCount, $data['id']));
    }

    function onUpdAction($action, $data, $ticket) {
        $api = $this->db->query("SELECT * FROM extapi WHERE id = ?", $action->id_extapi)->row();
        $apiinfo = json_decode($api->info);
        $endpoint = $action->endpoint;
        // si endpoint tiene llaves {}, las reemplaza por los valores de info
        if (strpos($endpoint, '{') !== false) {
            foreach ($apiinfo as $key => $value) {
                $endpoint = str_replace("{".$key."}", $value, $endpoint);
            }
        }
        // Si endpoint sigue teniendo llaves, se reemplaza por el valor en data
        if (strpos($endpoint, '{') !== false) {
            foreach ($data as $key => $value) {
                $endpoint = str_replace("{".$key."}", $value, $endpoint);
            }
        }
        // Si endpoint sigue teniendo llaves, se reemplaza por el valor en ticket
        if (strpos($endpoint, '{') !== false) {
            foreach ($ticket as $key => $value) {
                $endpoint = str_replace("{".$key."}", $value, $endpoint);
            }
        }
        if (strpos($endpoint, '{') !== false) {
            $this->db->query("INSERT INTO bago_log (`evento`, `data`, `fecha`) VALUES (?,?,NOW())",
                ["onUpdAction error", "Endpoint no se pudo completar: " . $endpoint]);
            return false;
        }
        $mod = json_decode($action->map_out_data);
        foreach ($mod as $key => $value) {
            $partes = explode(".", $value);
            $sec   = $partes[0];
            $parte = $partes[1];
            $cat   = (!empty($partes[2])) ? $partes[2] : "";
            $field = (!empty($partes[3])) ? $partes[3] : "";
            $tosend[$key] = "";
            if ($parte=="cats") {
                $rows = $this->db->query("SELECT * FROM formd_" . $data->id_form . "_cats WHERE field = ?", $field)->result();
                foreach ($rows as $row) {
                    if ($row->eti == $data->$cat) {
                        $tosend[$key] = $row->val;
                        break;
                    }
                }
            } else if (!empty($$sec->$parte)) {
                $tosend[$key] =  $$sec->$parte;
            }
        }
        $reqarray = ["url"=>$api->url . $endpoint,"method"=>$action->proto];
        if ($api->logloc == "0") {
            $reqarray["heads"] = [$api->sign . ": " . $api->token];
        } else if ($api->loglog == "1") {
            $tosend[$api->sign] = $api->token;
        }
        if ($api->valid_crt == "0") {
            $reqarray["nossl"] = true;
        }
        $reqarray["body"] = $tosend;
        $this->db->query("INSERT INTO bago_log (`evento`, `data`, `fecha`) VALUES (?,?,NOW())", ["onUpdAction request", json_encode($reqarray)]);
        $res = doReq($reqarray);
        $this->db->query("INSERT INTO bago_log (`evento`, `data`, `fecha`) VALUES (?,?,NOW())", ["onUpdAction response", json_encode($res)]);

        return true;
    }

}
